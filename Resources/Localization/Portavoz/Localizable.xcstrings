          }
        }
      }
    },
    "Voice match: sounds like “%@” from your remembered voices.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coincidencia de voz: suena como “%@” entre tus voces recordadas."
          }
