          }
        }
      }
    },
    "The refine covers much less speech than the current transcript — it probably failed. Do not apply it.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El refine cubre mucha menos voz que el transcript actual — probablemente falló. No lo apliques."
