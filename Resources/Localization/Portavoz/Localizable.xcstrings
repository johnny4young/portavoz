    "icloud cloud sync status existing library encrypted devices pause remove": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "icloud nube sincronización estado biblioteca existente cifrado dispositivos pausar quitar"
