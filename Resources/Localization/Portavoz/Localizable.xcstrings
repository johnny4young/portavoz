    "Remove this Mac from sync…": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quitar este Mac de la sincronización…"
          }
        }
      }
    },
    "This clears only this Mac's protected sync queue and consent. Local meetings stay here, and encrypted records already in iCloud are not deleted.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto borra solo la cola protegida de sincronización y el consentimiento de este Mac. Las reuniones locales permanecen aquí y los registros cifrados que ya están en iCloud no se eliminan."
          }
        }
      }
    },
    "Include existing library?": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Incluir la biblioteca existente?"
          }
        }
