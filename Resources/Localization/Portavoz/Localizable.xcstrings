    "iCloud sync": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronización con iCloud"
          }
        }
      }
    },
    "Encrypted meeting text and portable metadata sync through your private iCloud database. Audio, local file paths, voiceprints, secrets, and embeddings never sync.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El texto cifrado de las reuniones y los metadatos portátiles se sincronizan mediante tu base de datos privada de iCloud. El audio, las rutas de archivos locales, las huellas de voz, los secretos y los embeddings nunca se sincronizan."
          }
        }
      }
    },
    "Controls": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controles"
          }
        }
      }
    },
