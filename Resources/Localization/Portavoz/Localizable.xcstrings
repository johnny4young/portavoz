{
  "sourceLanguage": "en",
  "strings": {
    "%d model(s) available.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%d modelo(s) disponible(s)."
          }
        }
      }
    },
    "A token is stored in this device’s Keychain. It is used only when you publish a gist.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hay un token guardado en el Keychain de este equipo. Se usa solo cuando publicas un gist."
          }
        }
      }
    },
    "API key": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Clave API"
          }
        }
      }
    },
    "Acronyms, products, and proper names from your meetings. They guide quality transcription and summaries so “LVGT” does not become something else.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siglas, productos y nombres propios de tus reuniones. Guían la transcripción de calidad y los resúmenes para que “LVGT” no se convierta en otra cosa."
          }
        }
      }
    },
    "Add": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar"
          }
        }
      }
    },
    "Add a note…": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar una nota…"
          }
        }
      }
    },
    "Add note (⏎)": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar nota (⏎)"
          }
        }
